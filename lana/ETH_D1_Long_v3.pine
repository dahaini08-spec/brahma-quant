//@version=5
indicator("ETH D1-ATR 做多 v3 [梵天拉娜]", overlay=true, max_labels_count=300, max_lines_count=100, max_boxes_count=100)

// ═══════════════════════════════════════════════════════════════════
// 梵天猎手-拉娜 · ETH 1H 专项做多引擎 v3
// 升级：多时框4H确认 + 渐变填充 + 动态追踪止损 + 仓位计算 + 入场等待区
// 数据依据：8年回测 ETH 1H D1信号 胜率90% 期望+1.15%/笔
// ═══════════════════════════════════════════════════════════════════

// ─── 参数 ────────────────────────────────────────────────────────────────────
g1="🔬 ATR参数" | g2="🚀 突破参数" | g3="🎯 止损止盈" | g4="🔍 过滤器" | g5="💰 仓位管理" | g6="🖥 视觉"

atr_len        = input.int(14,    "ATR周期",              group=g1)
atr_hist       = input.int(50,    "ATR历史均值回望",       group=g1)
atr_mult       = input.float(1.1, "ATR扩张门槛",          group=g1, step=0.05, minval=1.0)
brk_bars       = input.int(20,    "突破回望根数",          group=g2)
brk_margin     = input.float(0.1, "突破边距(%)",           group=g2, step=0.05)
vol_min        = input.float(1.2, "最低量比",              group=g2, step=0.1)
sl_bars        = input.int(8,     "结构止损回望",          group=g3)
t1_mult        = input.float(1.5, "T1 × ATR",             group=g3, step=0.1)
t2_mult        = input.float(3.0, "T2 × ATR",             group=g3, step=0.1)
t3_mult        = input.float(5.0, "T3 × ATR",             group=g3, step=0.1)
use_ema        = input.bool(true,  "EMA趋势过滤(1H)",      group=g4)
ema_f          = input.int(20,    "EMA快线",               group=g4)
ema_s          = input.int(50,    "EMA慢线",               group=g4)
use_mtf        = input.bool(true,  "4H多时框确认",         group=g4)
use_rsi        = input.bool(true,  "RSI过滤(>75不进)",     group=g4)
use_retest     = input.bool(false, "等待回踩再入场",        group=g4)
account_size   = input.float(1525, "账户USDT",             group=g5)
risk_pct       = input.float(2.0,  "单笔风险(%)",          group=g5, step=0.5)
leverage       = input.int(10,    "杠杆倍数",              group=g5)
show_ema_lines = input.bool(true,  "显示EMA",              group=g6)
show_dash      = input.bool(true,  "显示仪表盘",           group=g6)
show_box       = input.bool(true,  "显示信号框",           group=g6)
show_fill      = input.bool(true,  "显示渐变区间",         group=g6)
show_trail     = input.bool(true,  "显示追踪止损",         group=g6)
cooldown_n     = input.int(4,      "冷却根数",             group=g6)

// ─── 颜色主题（币安暗色专业版）─────────────────────────────────────────────
C_BULL    = #26A69A
C_SL      = #EF5350
C_T1      = #66BB6A
C_T2      = #43A047
C_T3      = #1B5E20
C_EMA_F   = #FFA726
C_EMA_S   = #AB47BC
C_TRAIL   = #FF6F00
C_BG      = #1E2329
C_GOLD    = #F0B90B
C_TXT     = #ECEFF1
C_GRAY    = #757575

// ─── 1H 指标计算 ─────────────────────────────────────────────────────────────
atr_now    = ta.atr(atr_len)
atr_mean   = ta.sma(atr_now, atr_hist)
atr_ratio  = atr_mean > 0 ? atr_now / atr_mean : 1.0
atr_pct    = close > 0 ? atr_now / close * 100 : 0.0
vol_avg    = ta.sma(volume, 20)
vol_ratio  = vol_avg > 0 ? volume / vol_avg : 1.0
ema_f_val  = ta.ema(close, ema_f)
ema_s_val  = ta.ema(close, ema_s)
rsi_val    = ta.rsi(close, 14)
obv_val    = ta.obv
obv_ema    = ta.ema(obv_val, 20)
obv_bull   = obv_val > obv_ema

// ─── 4H 多时框（请求4H数据）────────────────────────────────────────────────
ema50_4h   = request.security(syminfo.tickerid, "240", ta.ema(close, 50), lookahead=barmerge.lookahead_off)
ema20_4h   = request.security(syminfo.tickerid, "240", ta.ema(close, 20), lookahead=barmerge.lookahead_off)
close_4h   = request.security(syminfo.tickerid, "240", close,             lookahead=barmerge.lookahead_off)
atr_4h     = request.security(syminfo.tickerid, "240", ta.atr(14),        lookahead=barmerge.lookahead_off)
rsi_4h     = request.security(syminfo.tickerid, "240", ta.rsi(close, 14), lookahead=barmerge.lookahead_off)
mtf_bull   = close_4h > ema20_4h and ema20_4h > ema50_4h

// ─── 突破与止损 ───────────────────────────────────────────────────────────────
prev_hi    = ta.highest(high[1], brk_bars)
prev_lo    = ta.lowest(low[1],   sl_bars)
brk_up     = close > prev_hi * (1.0 + brk_margin / 100.0)

// 回踩等待区（突破后价格回到前高附近）
retest_zone = use_retest ? (close <= prev_hi * 1.005 and close >= prev_hi * 0.995) : true

sl_price   = prev_lo  * 0.998
sl_dist    = close > 0 ? (close - sl_price) / close * 100 : 0.0
t1_price   = close + t1_mult * atr_now
t2_price   = close + t2_mult * atr_now
t3_price   = close + t3_mult * atr_now
rr1        = (close - sl_price) > 0 ? (t1_price - close) / (close - sl_price) : 0.0
rr2        = (close - sl_price) > 0 ? (t2_price - close) / (close - sl_price) : 0.0

// ─── 仓位计算 ────────────────────────────────────────────────────────────────
risk_usd     = account_size * risk_pct / 100
sl_usd       = close > 0 ? sl_dist / 100 * close : 1.0
pos_size_usd = sl_usd > 0 ? risk_usd / (sl_dist / 100) : 0.0
pos_size_lev = pos_size_usd * leverage
pos_eth      = close > 0 ? pos_size_lev / close : 0.0

// ─── 过滤器 ──────────────────────────────────────────────────────────────────
f_ema        = use_ema  ? (close > ema_f_val and ema_f_val > ema_s_val) : true
f_mtf        = use_mtf  ? mtf_bull : true
f_rsi        = use_rsi  ? (rsi_val < 75.0) : true
f_vol        = vol_ratio >= vol_min
f_atr        = atr_ratio >= atr_mult
f_brk        = brk_up
f_sl         = sl_dist >= 0.2 and sl_dist <= 8.0
f_rr         = rr1 >= 1.2
f_retest     = retest_zone

long_ok      = f_atr and f_brk and f_vol and f_sl and f_rr and f_ema and f_mtf and f_rsi and f_retest

var int last_bar = -999
long_fire    = long_ok and (bar_index - last_bar) >= cooldown_n
if long_fire
    last_bar := bar_index

// ─── 评分系统（5维 0~100）────────────────────────────────────────────────────
sc_atr  = atr_ratio >= 1.5 ? 20 : atr_ratio >= 1.3 ? 15 : atr_ratio >= 1.1 ? 10 : 3
sc_vol  = vol_ratio >= 3.0 ? 20 : vol_ratio >= 2.0 ? 15 : vol_ratio >= 1.5 ? 10 : 5
sc_rr   = rr1 >= 3.0 ? 20 : rr1 >= 2.0 ? 15 : rr1 >= 1.5 ? 10 : 5
sc_rsi  = rsi_val <= 35 ? 20 : rsi_val <= 50 ? 15 : rsi_val <= 65 ? 8 : 2
sc_mtf  = mtf_bull ? 20 : 0
sc_obv  = obv_bull ? 5 : 0
sc_tot  = sc_atr + sc_vol + sc_rr + sc_rsi + sc_mtf + sc_obv
grade   = sc_tot >= 80 ? "S+" : sc_tot >= 70 ? "S" : sc_tot >= 55 ? "A" : sc_tot >= 40 ? "B" : "C"
g_col   = sc_tot >= 80 ? C_GOLD : sc_tot >= 70 ? #26A69A : sc_tot >= 55 ? #7E57C2 : C_GRAY

// ─── EMA均线 ─────────────────────────────────────────────────────────────────
plot(show_ema_lines ? ema_f_val : na, "EMA" + str.tostring(ema_f), color=color.new(C_EMA_F, 20), linewidth=1)
plot(show_ema_lines ? ema_s_val : na, "EMA" + str.tostring(ema_s), color=color.new(C_EMA_S, 20), linewidth=2)

// ─── 信号箭头 ────────────────────────────────────────────────────────────────
plotshape(long_fire, title="做多▲", location=location.belowbar, style=shape.triangleup, size=size.normal, color=color.new(C_BULL, 0))

// ─── 信号标签（完整信息）────────────────────────────────────────────────────
if long_fire
    lbl = "▲ ETH LONG  [" + grade + "]\n"
        + "入场  " + str.tostring(close, "#.00") + "\n"
        + "SL    " + str.tostring(sl_price, "#.00") + "  -" + str.tostring(sl_dist, "#.##") + "%\n"
        + "T1    " + str.tostring(t1_price, "#.00") + "  RR=" + str.tostring(rr1, "#.#") + "\n"
        + "T2    " + str.tostring(t2_price, "#.00") + "  RR=" + str.tostring(rr2, "#.#") + "\n"
        + "仓位  " + str.tostring(pos_size_lev, "#.0") + "U  " + str.tostring(pos_eth, "#.####") + "ETH\n"
        + "4H趋势 " + (mtf_bull ? "✅顺" : "❌逆") + "  分=" + str.tostring(sc_tot) + "/105"
    label.new(bar_index, low - atr_now * 1.5, text=lbl, style=label.style_label_up, color=color.new(C_BULL, 5), textcolor=color.white, size=size.small, textalign=text.align_left)

// ─── 信号K线高亮框 ───────────────────────────────────────────────────────────
if long_fire and show_box
    box.new(bar_index - 1, high + atr_now * 0.2, bar_index + 1, low - atr_now * 0.2, border_color=color.new(C_BULL, 20), border_width=2, bgcolor=color.new(C_BULL, 85))

// ─── 止损/止盈线（line.new）─────────────────────────────────────────────────
var line l_sl = na
var line l_t1 = na
var line l_t2 = na
var line l_t3 = na
var line l_tr = na

if long_fire
    if not na(l_sl) | not na(l_t1)
        line.delete(l_sl)
        line.delete(l_t1)
        line.delete(l_t2)
        line.delete(l_t3)
    l_sl := line.new(bar_index, sl_price,  bar_index + 80, sl_price,  color=color.new(C_SL,  0), width=2, style=line.style_dashed, extend=extend.right)
    l_t1 := line.new(bar_index, t1_price,  bar_index + 80, t1_price,  color=color.new(C_T1,  0), width=2, style=line.style_dashed, extend=extend.right)
    l_t2 := line.new(bar_index, t2_price,  bar_index + 80, t2_price,  color=color.new(C_T2,  0), width=2, style=line.style_dashed, extend=extend.right)
    l_t3 := line.new(bar_index, t3_price,  bar_index + 80, t3_price,  color=color.new(C_T3,  0), width=3, style=line.style_dashed, extend=extend.right)
    label.new(bar_index + 2, sl_price,  "SL " + str.tostring(sl_price, "#.00"),  style=label.style_label_right, color=color.new(C_SL, 0),  textcolor=color.white, size=size.tiny)
    label.new(bar_index + 2, t1_price,  "T1 " + str.tostring(t1_price, "#.00"),  style=label.style_label_right, color=color.new(C_T1, 0),  textcolor=color.white, size=size.tiny)
    label.new(bar_index + 2, t2_price,  "T2 " + str.tostring(t2_price, "#.00"),  style=label.style_label_right, color=color.new(C_T2, 0),  textcolor=color.white, size=size.tiny)
    label.new(bar_index + 2, t3_price,  "T3 " + str.tostring(t3_price, "#.00"),  style=label.style_label_right, color=color.new(C_T3, 0),  textcolor=color.white, size=size.tiny)

// ─── 渐变填充（SL→T1→T2→T3）────────────────────────────────────────────────
var float v_sl = na
var float v_t1 = na
var float v_t2 = na
var float v_t3 = na
if long_fire
    v_sl := sl_price
    v_t1 := t1_price
    v_t2 := t2_price
    v_t3 := t3_price

p_sl  = plot(show_fill ? v_sl : na, display=display.none)
p_t1  = plot(show_fill ? v_t1 : na, display=display.none)
p_t2  = plot(show_fill ? v_t2 : na, display=display.none)
p_t3  = plot(show_fill ? v_t3 : na, display=display.none)
p_c   = plot(close, display=display.none)
fill(p_sl, p_c,  color=color.new(C_SL, 92), title="SL区间")
fill(p_c,  p_t1, color=color.new(C_T1, 90), title="T1区间")
fill(p_t1, p_t2, color=color.new(C_T2, 92), title="T2区间")
fill(p_t2, p_t3, color=color.new(C_T3, 94), title="T3区间")

// ─── 动态追踪止损（T1触达后自动上移到入场价）────────────────────────────────
var float trail_sl    = na
var float entry_price = na
var bool  in_trade    = false

if long_fire
    entry_price := close
    trail_sl    := sl_price
    in_trade    := true

if in_trade and not na(entry_price)
    // T1触达 → 追踪止损上移到入场价（保本）
    if high >= entry_price + t1_mult * atr_now[1]
        trail_sl := entry_price
    // T2触达 → 追踪止损上移到T1
    if high >= entry_price + t2_mult * atr_now[1]
        trail_sl := entry_price + t1_mult * atr_now[1]
    // 止损触发 → 清仓
    if low <= trail_sl
        in_trade    := false
        trail_sl    := na
        entry_price := na

if show_trail and not na(l_tr)
    line.delete(l_tr)
if show_trail and in_trade and not na(trail_sl)
    l_tr := line.new(bar_index, trail_sl, bar_index + 1, trail_sl, color=color.new(C_TRAIL, 0), width=2, style=line.style_solid, extend=extend.right)

plotshape(show_trail and in_trade and not na(trail_sl) and low <= trail_sl, title="追踪止损触发", location=location.belowbar, style=shape.xcross, size=size.small, color=color.new(C_TRAIL, 0))

// ─── 实时仪表盘 ──────────────────────────────────────────────────────────────
if show_dash and barstate.islast
    var table d = table.new(position.top_right, 2, 14, bgcolor=color.new(C_BG, 5), border_color=color.new(#2A2A2A, 0), border_width=1, frame_color=color.new(C_GOLD, 40), frame_width=1)

    // 标题
    table.cell(d, 0, 0, "🔱 梵天拉娜  ETH 1H 做多", bgcolor=color.new(#0B0E11, 0), text_color=color.new(C_GOLD, 0), text_size=size.small, text_halign=text.align_center)
    table.merge_cells(d, 0, 0, 1, 0)

    // Gate状态
    mk(ok) => ok ? "✅" : "❌"
    table.cell(d, 0, 1,  "ATR扩张",   text_color=color.new(C_TXT,  0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))
    table.cell(d, 1, 1,  mk(f_atr) + " " + str.tostring(atr_ratio, "#.##") + "×  " + str.tostring(atr_pct, "#.##") + "%", text_color=f_atr ? color.new(C_BULL, 0) : color.new(C_GRAY, 0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))
    table.cell(d, 0, 2,  "结构突破",   text_color=color.new(C_TXT,  0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))
    table.cell(d, 1, 2,  mk(f_brk) + (f_brk ? " 突破 " + str.tostring(prev_hi, "#.00") : " 未突破"), text_color=f_brk ? color.new(C_BULL, 0) : color.new(C_GRAY, 0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))
    table.cell(d, 0, 3,  "量比",       text_color=color.new(C_TXT,  0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))
    table.cell(d, 1, 3,  mk(f_vol) + " " + str.tostring(vol_ratio, "#.##") + "×", text_color=f_vol ? color.new(C_BULL, 0) : color.new(C_GRAY, 0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))
    table.cell(d, 0, 4,  "1H趋势",     text_color=color.new(C_TXT,  0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))
    table.cell(d, 1, 4,  mk(f_ema) + (f_ema ? " 多头排列" : " 未排列"), text_color=f_ema ? color.new(C_BULL, 0) : color.new(C_GRAY, 0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))
    table.cell(d, 0, 5,  "4H趋势",     text_color=color.new(C_TXT,  0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))
    table.cell(d, 1, 5,  mk(f_mtf) + (mtf_bull ? " 多头  RSI" + str.tostring(rsi_4h, "#.#") : " 空头  RSI" + str.tostring(rsi_4h, "#.#")), text_color=mtf_bull ? color.new(C_BULL, 0) : color.new(C_SL, 0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))
    rsi_c = rsi_val < 40 ? C_BULL : rsi_val < 65 ? C_GOLD : C_SL
    table.cell(d, 0, 6,  "RSI(1H)",    text_color=color.new(C_TXT,  0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))
    table.cell(d, 1, 6,  str.tostring(rsi_val, "#.#") + (rsi_val < 40 ? " 超卖✅" : rsi_val > 70 ? " 超买⚠️" : " 正常"), text_color=color.new(rsi_c, 0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))
    table.cell(d, 0, 7,  "OBV趋势",    text_color=color.new(C_TXT,  0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))
    table.cell(d, 1, 7,  obv_bull ? "✅ 量能支撑" : "⚠️ 量能偏弱", text_color=obv_bull ? color.new(C_BULL, 0) : color.new(C_GOLD, 0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))

    // 分隔线
    table.cell(d, 0, 8, "─────────", text_color=color.new(#333333, 0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))
    table.cell(d, 1, 8, "─────────", text_color=color.new(#333333, 0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))

    // 仓位信息
    table.cell(d, 0, 9,  "评分",       text_color=color.new(C_TXT,  0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))
    table.cell(d, 1, 9,  str.tostring(sc_tot) + "/105  [" + grade + "]", text_color=color.new(g_col, 0), text_size=size.small, bgcolor=color.new(C_BG, 0))
    table.cell(d, 0, 10, "建议仓位",   text_color=color.new(C_TXT,  0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))
    table.cell(d, 1, 10, str.tostring(pos_size_lev, "#.0") + " USDT  " + str.tostring(pos_eth, "#.####") + " ETH", text_color=color.new(C_GOLD, 0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))
    table.cell(d, 0, 11, "风险金额",   text_color=color.new(C_TXT,  0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))
    table.cell(d, 1, 11, str.tostring(risk_usd, "#.0") + " USDT  (" + str.tostring(risk_pct, "#.#") + "%)", text_color=color.new(C_SL, 0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))

    // 信号状态
    sig_txt = long_fire ? "🔥 信号触发！" : long_ok ? "⚡ 条件满足" : "💤 等待信号"
    sig_col = long_fire ? C_GOLD : long_ok ? C_BULL : C_GRAY
    table.cell(d, 0, 12, "信号状态",   text_color=color.new(C_TXT,  0), text_size=size.small, bgcolor=color.new(#0B0E11, 0))
    table.cell(d, 1, 12, sig_txt,       text_color=color.new(sig_col, 0), text_size=size.small, bgcolor=color.new(#0B0E11, 0))

    // 追踪止损状态
    trail_txt = in_trade and not na(trail_sl) ? "🔶 追踪中 " + str.tostring(trail_sl, "#.00") : "—"
    table.cell(d, 0, 13, "追踪止损",   text_color=color.new(C_TXT,  0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))
    table.cell(d, 1, 13, trail_txt,     text_color=color.new(C_TRAIL, 0), text_size=size.tiny, bgcolor=color.new(C_BG, 0))

// ─── ATR扩张背景 ─────────────────────────────────────────────────────────────
bgcolor(atr_ratio >= atr_mult and mtf_bull ? color.new(#E3F2FD, 93) : atr_ratio >= atr_mult ? color.new(#FFF9C4, 90) : na, title="ATR扩张背景")

// ─── 警报（含完整信息）──────────────────────────────────────────────────────
alertcondition(long_fire, "ETH D1 做多[梵天拉娜]", "ETH LONG 信号触发 | 评分" + str.tostring(sc_tot) + "[" + grade + "] | 入场" + str.tostring(close, "#.00") + " | SL" + str.tostring(sl_price, "#.00") + " | T1" + str.tostring(t1_price, "#.00") + " | 仓位" + str.tostring(pos_size_lev, "#.0") + "U")
