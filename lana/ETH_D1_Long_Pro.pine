//@version=5
indicator("ETH D1-ATR 做多信号 [梵天拉娜]", overlay=true, max_labels_count=300, max_lines_count=100, max_boxes_count=100)

// ═══════════════════════════════════════════════════════════════════
// 梵天猎手-拉娜 · ETH 1H 专项做多引擎
// 数据依据：8年回测 ETH 1H D1信号 胜率90% 期望+1.15%/笔
// 核心逻辑：ATR扩张 × 结构突破 × 量比确认 × 趋势过滤
// ═══════════════════════════════════════════════════════════════════

// ─── 参数组 ────────────────────────────────────────────────────────
g1 = "🔬 ATR参数"
g2 = "🚀 突破参数"
g3 = "🎯 止损止盈"
g4 = "🔍 趋势过滤"
g5 = "🖥 视觉设置"

atr_len         = input.int(14,    "ATR周期",            group=g1)
atr_hist        = input.int(50,    "ATR历史均值回望",     group=g1)
atr_mult        = input.float(1.1, "ATR扩张门槛 ×均值",  group=g1, step=0.05, minval=1.0)

brk_bars        = input.int(20,    "突破回望根数",        group=g2)
brk_margin      = input.float(0.1, "突破确认边距(%)",     group=g2, step=0.05)
vol_min         = input.float(1.2, "最低量比",            group=g2, step=0.1)

sl_bars         = input.int(8,     "结构止损回望根数",    group=g3)
t1_mult         = input.float(1.5, "T1 × ATR",           group=g3, step=0.1)
t2_mult         = input.float(3.0, "T2 × ATR",           group=g3, step=0.1)
t3_mult         = input.float(5.0, "T3 × ATR",           group=g3, step=0.1)

use_trend       = input.bool(true,  "启用EMA趋势过滤",    group=g4)
ema_fast        = input.int(20,    "EMA快线",             group=g4)
ema_slow        = input.int(50,    "EMA慢线",             group=g4)
use_rsi_filter  = input.bool(true,  "RSI超买过滤(>75不进)", group=g4)

show_ema        = input.bool(true,  "显示EMA均线",        group=g5)
show_dashboard  = input.bool(true,  "显示实时仪表盘",     group=g5)
show_box        = input.bool(true,  "显示信号区域框",     group=g5)
cooldown_n      = input.int(4,      "同方向冷却根数",     group=g5)

// ─── 颜色定义（专业暗色主题适配）──────────────────────────────────
c_bull      = #26A69A   // 入场青绿
c_sl        = #EF5350   // 止损红
c_t1        = #66BB6A   // T1绿
c_t2        = #43A047   // T2深绿
c_t3        = #2E7D32   // T3更深绿
c_ema_f     = #FFA726   // EMA快线橙
c_ema_s     = #7E57C2   // EMA慢线紫
c_dash_bg   = #1E2329   // 仪表盘背景（币安暗色）
c_dash_txt  = #F0F0F0   // 仪表盘文字
c_dash_hi   = #F0B90B   // 仪表盘高亮（币安黄）

// ─── 核心指标计算 ─────────────────────────────────────────────────
atr_now    = ta.atr(atr_len)
atr_mean   = ta.sma(atr_now, atr_hist)
atr_ratio  = atr_mean > 0 ? atr_now / atr_mean : 1.0
atr_pct    = close > 0 ? atr_now / close * 100 : 0.0

vol_avg    = ta.sma(volume, 20)
vol_ratio  = vol_avg > 0 ? volume / vol_avg : 1.0

ema_f_val  = ta.ema(close, ema_fast)
ema_s_val  = ta.ema(close, ema_slow)

rsi_val    = ta.rsi(close, 14)

// 突破判断（排除当前K线自身）
prev_hi    = ta.highest(high[1], brk_bars)
prev_lo    = ta.lowest(low[1],   sl_bars)
brk_up     = close > prev_hi * (1.0 + brk_margin / 100.0)

// 结构止损
sl_price   = prev_lo * 0.998
sl_dist    = close > 0 ? (close - sl_price) / close * 100 : 0.0

// ATR止盈
t1_price   = close + t1_mult * atr_now
t2_price   = close + t2_mult * atr_now
t3_price   = close + t3_mult * atr_now

// 盈亏比
rr1        = (close - sl_price) > 0 ? (t1_price - close) / (close - sl_price) : 0.0

// ─── 趋势过滤 ────────────────────────────────────────────────────
trend_ok   = use_trend ? (close > ema_f_val and ema_f_val > ema_s_val) : true
rsi_ok     = use_rsi_filter ? (rsi_val < 75.0) : true

// ─── 信号触发条件 ─────────────────────────────────────────────────
gate_atr   = atr_ratio  >= atr_mult
gate_brk   = brk_up
gate_vol   = vol_ratio  >= vol_min
gate_sl    = sl_dist    >= 0.2 and sl_dist <= 8.0
gate_rr    = rr1        >= 1.2
gate_trend = trend_ok
gate_rsi   = rsi_ok

long_ok    = gate_atr and gate_brk and gate_vol and gate_sl and gate_rr and gate_trend and gate_rsi

// ─── 冷却过滤 ────────────────────────────────────────────────────
var int last_bar = -999
long_fire  = long_ok and (bar_index - last_bar) >= cooldown_n
if long_fire
    last_bar := bar_index

// ─── 信号强度评分（0~100）────────────────────────────────────────
score_atr  = atr_ratio >= 1.5 ? 30 : atr_ratio >= 1.3 ? 22 : atr_ratio >= 1.1 ? 14 : 5
score_vol  = vol_ratio >= 3.0 ? 25 : vol_ratio >= 2.0 ? 18 : vol_ratio >= 1.5 ? 12 : 6
score_rr   = rr1       >= 2.5 ? 20 : rr1       >= 2.0 ? 15 : rr1       >= 1.5 ? 10 : 5
score_rsi  = rsi_val   <= 40  ? 15 : rsi_val   <= 55  ? 10 : rsi_val   <= 65  ? 5  : 2
score_tot  = score_atr + score_vol + score_rr + score_rsi

grade      = score_tot >= 75 ? "S级" : score_tot >= 60 ? "A级" : score_tot >= 45 ? "B级" : "C级"
grade_col  = score_tot >= 75 ? #F0B90B : score_tot >= 60 ? #26A69A : score_tot >= 45 ? #7E57C2 : #9E9E9E

// ─── EMA均线显示 ─────────────────────────────────────────────────
plot(show_ema ? ema_f_val : na, "EMA" + str.tostring(ema_fast), color=color.new(c_ema_f, 20), linewidth=1)
plot(show_ema ? ema_s_val : na, "EMA" + str.tostring(ema_slow), color=color.new(c_ema_s, 20), linewidth=2)

// ─── 入场信号：箭头 ──────────────────────────────────────────────
plotshape(long_fire, title="做多信号", location=location.belowbar, style=shape.triangleup, size=size.normal, color=color.new(c_bull, 0))

// ─── 入场信号：详细标签 ──────────────────────────────────────────
if long_fire
    lbl_text = "▲ ETH LONG  " + grade + "\n入场  " + str.tostring(close, "#.00") + "\nSL    " + str.tostring(sl_price, "#.00") + "  (-" + str.tostring(sl_dist, "#.##") + "%)\nT1    " + str.tostring(t1_price, "#.00") + "\nT2    " + str.tostring(t2_price, "#.00") + "\nRR    " + str.tostring(rr1, "#.##") + "  分" + str.tostring(score_tot)
    label.new(bar_index, low - atr_now * 1.2, text=lbl_text, style=label.style_label_up, color=color.new(c_bull, 5), textcolor=color.white, size=size.small, textalign=text.align_left)

// ─── 信号区域框（入场Bar可视化）─────────────────────────────────
if long_fire and show_box
    box.new(bar_index - 1, high, bar_index + 1, low, border_color=color.new(c_bull, 30), border_width=2, bgcolor=color.new(c_bull, 88))

// ─── 止损/止盈 水平线（最新信号）────────────────────────────────
var line l_sl = na
var line l_t1 = na
var line l_t2 = na
var line l_t3 = na

if long_fire
    if not na(l_sl)
        line.delete(l_sl)
        line.delete(l_t1)
        line.delete(l_t2)
        line.delete(l_t3)
    l_sl := line.new(bar_index, sl_price,  bar_index + 60, sl_price,  color=color.new(c_sl, 0),  width=2, style=line.style_dashed, extend=extend.right)
    l_t1 := line.new(bar_index, t1_price,  bar_index + 60, t1_price,  color=color.new(c_t1, 0),  width=2, style=line.style_dashed, extend=extend.right)
    l_t2 := line.new(bar_index, t2_price,  bar_index + 60, t2_price,  color=color.new(c_t2, 0),  width=2, style=line.style_dashed, extend=extend.right)
    l_t3 := line.new(bar_index, t3_price,  bar_index + 60, t3_price,  color=color.new(c_t3, 0),  width=2, style=line.style_dashed, extend=extend.right)

// ─── 止损线标签 ──────────────────────────────────────────────────
if long_fire
    label.new(bar_index + 3, sl_price,  "SL  " + str.tostring(sl_price, "#.00"),  style=label.style_label_right, color=color.new(c_sl, 0),  textcolor=color.white, size=size.tiny)
    label.new(bar_index + 3, t1_price,  "T1  " + str.tostring(t1_price, "#.00"),  style=label.style_label_right, color=color.new(c_t1, 0),  textcolor=color.white, size=size.tiny)
    label.new(bar_index + 3, t2_price,  "T2  " + str.tostring(t2_price, "#.00"),  style=label.style_label_right, color=color.new(c_t2, 0),  textcolor=color.white, size=size.tiny)
    label.new(bar_index + 3, t3_price,  "T3  " + str.tostring(t3_price, "#.00"),  style=label.style_label_right, color=color.new(c_t3, 0),  textcolor=color.white, size=size.tiny)

// ─── 实时仪表盘（右上角信息表）──────────────────────────────────
if show_dashboard and barstate.islast
    var table dash = table.new(position.top_right, 2, 10, bgcolor=color.new(c_dash_bg, 10), border_color=color.new(#333333, 0), border_width=1, frame_color=color.new(c_dash_hi, 30), frame_width=1)

    // 标题行
    table.cell(dash, 0, 0, "🔱 梵天拉娜 ETH 1H", text_color=color.new(c_dash_hi, 0), text_size=size.small, bgcolor=color.new(c_dash_bg, 0), text_halign=text.align_center)
    table.cell(dash, 1, 0, "D1-ATR做多", text_color=color.new(c_dash_hi, 0), text_size=size.small, bgcolor=color.new(c_dash_bg, 0), text_halign=text.align_center)
    table.merge_cells(dash, 0, 0, 1, 0)

    // ATR状态
    atr_status_txt = atr_ratio >= atr_mult ? "✅ 扩张×" + str.tostring(atr_ratio, "#.##") : "⏳ 等待×" + str.tostring(atr_ratio, "#.##")
    atr_status_col = atr_ratio >= atr_mult ? #26A69A : #9E9E9E
    table.cell(dash, 0, 1, "ATR扩张", text_color=color.new(c_dash_txt, 0), text_size=size.tiny, bgcolor=color.new(c_dash_bg, 0))
    table.cell(dash, 1, 1, atr_status_txt, text_color=color.new(atr_status_col, 0), text_size=size.tiny, bgcolor=color.new(c_dash_bg, 0))

    // 量比状态
    vol_status_txt = vol_ratio >= vol_min ? "✅ " + str.tostring(vol_ratio, "#.##") + "x" : "❌ " + str.tostring(vol_ratio, "#.##") + "x"
    vol_status_col = vol_ratio >= vol_min ? #26A69A : #EF5350
    table.cell(dash, 0, 2, "量比", text_color=color.new(c_dash_txt, 0), text_size=size.tiny, bgcolor=color.new(c_dash_bg, 0))
    table.cell(dash, 1, 2, vol_status_txt, text_color=color.new(vol_status_col, 0), text_size=size.tiny, bgcolor=color.new(c_dash_bg, 0))

    // 突破状态
    brk_txt = brk_up ? "✅ 已突破" : "❌ 未突破"
    brk_col = brk_up ? #26A69A : #EF5350
    table.cell(dash, 0, 3, "结构突破", text_color=color.new(c_dash_txt, 0), text_size=size.tiny, bgcolor=color.new(c_dash_bg, 0))
    table.cell(dash, 1, 3, brk_txt, text_color=color.new(brk_col, 0), text_size=size.tiny, bgcolor=color.new(c_dash_bg, 0))

    // 趋势状态
    trend_txt = trend_ok ? "✅ 顺势" : "❌ 逆势"
    trend_col = trend_ok ? #26A69A : #EF5350
    table.cell(dash, 0, 4, "趋势过滤", text_color=color.new(c_dash_txt, 0), text_size=size.tiny, bgcolor=color.new(c_dash_bg, 0))
    table.cell(dash, 1, 4, trend_txt, text_color=color.new(trend_col, 0), text_size=size.tiny, bgcolor=color.new(c_dash_bg, 0))

    // RSI
    rsi_txt = str.tostring(rsi_val, "#.#")
    rsi_col = rsi_val < 40 ? #26A69A : rsi_val < 60 ? c_dash_hi : #EF5350
    table.cell(dash, 0, 5, "RSI(14)", text_color=color.new(c_dash_txt, 0), text_size=size.tiny, bgcolor=color.new(c_dash_bg, 0))
    table.cell(dash, 1, 5, rsi_txt, text_color=color.new(rsi_col, 0), text_size=size.tiny, bgcolor=color.new(c_dash_bg, 0))

    // ATR百分比
    table.cell(dash, 0, 6, "ATR%", text_color=color.new(c_dash_txt, 0), text_size=size.tiny, bgcolor=color.new(c_dash_bg, 0))
    table.cell(dash, 1, 6, str.tostring(atr_pct, "#.##") + "%", text_color=color.new(c_dash_txt, 0), text_size=size.tiny, bgcolor=color.new(c_dash_bg, 0))

    // 综合评分
    table.cell(dash, 0, 7, "信号评分", text_color=color.new(c_dash_txt, 0), text_size=size.tiny, bgcolor=color.new(c_dash_bg, 0))
    table.cell(dash, 1, 7, str.tostring(score_tot) + "/90  " + grade, text_color=color.new(grade_col, 0), text_size=size.tiny, bgcolor=color.new(c_dash_bg, 0))

    // 信号状态
    sig_txt = long_fire ? "🔥 信号触发！" : long_ok ? "⚡ 条件满足" : "💤 等待信号"
    sig_col = long_fire ? #F0B90B : long_ok ? #26A69A : #757575
    table.cell(dash, 0, 8, "信号状态", text_color=color.new(c_dash_txt, 0), text_size=size.small, bgcolor=color.new(c_dash_bg, 0))
    table.cell(dash, 1, 8, sig_txt, text_color=color.new(sig_col, 0), text_size=size.small, bgcolor=color.new(c_dash_bg, 0))

    // 数据来源
    table.cell(dash, 0, 9, "回测胜率", text_color=color.new(#757575, 0), text_size=size.tiny, bgcolor=color.new(c_dash_bg, 0))
    table.cell(dash, 1, 9, "90%  EV+1.15%", text_color=color.new(#757575, 0), text_size=size.tiny, bgcolor=color.new(c_dash_bg, 0))

// ─── ATR扩张背景（仅扩张中）─────────────────────────────────────
bgcolor(atr_ratio >= atr_mult ? color.new(#FFF176, 90) : na, title="ATR扩张背景")

// ─── 警报 ─────────────────────────────────────────────────────────
alertcondition(long_fire, "ETH D1 做多信号", "梵天拉娜 ETH 1H 做多信号触发 | 评分: " + str.tostring(score_tot) + " | ATR×" + str.tostring(atr_ratio, "#.##"))
