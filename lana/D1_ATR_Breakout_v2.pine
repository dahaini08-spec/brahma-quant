//@version=5
indicator("D1-ATR扩张突破 [梵天拉娜] v2", overlay=true, max_labels_count=500)

// ─── 参数 ─────────────────────────────────────────────────────────────────────
atr_len         = input.int(14,   "ATR周期",        group="ATR参数")
atr_hist_bars   = input.int(50,   "ATR历史均值回望", group="ATR参数")
atr_expand_mult = input.float(1.1,"ATR扩张门槛",    group="ATR参数", step=0.05)
brk_bars        = input.int(20,   "突破回望根数",    group="突破参数")
brk_margin      = input.float(0.1,"突破边距(%)",     group="突破参数", step=0.05)
vol_min         = input.float(1.2,"最低量比",        group="突破参数", step=0.1)
sl_bars         = input.int(8,    "止损回望根数",    group="止损止盈")
t1_mult         = input.float(1.5,"T1 x ATR",       group="止损止盈", step=0.1)
t2_mult         = input.float(3.0,"T2 x ATR",       group="止损止盈", step=0.1)
t3_mult         = input.float(5.0,"T3 x ATR",       group="止损止盈", step=0.1)
min_rr1         = input.float(1.2,"最低盈亏比",      group="止损止盈", step=0.1)
show_long       = input.bool(true,"显示多头信号",    group="显示")
show_short      = input.bool(true,"显示空头信号",    group="显示")
show_levels     = input.bool(true,"显示止盈止损线",  group="显示")
show_bg         = input.bool(true,"显示ATR扩张背景", group="显示")
cooldown_n      = input.int(4,    "冷却根数",        group="显示")

// ─── 计算 ─────────────────────────────────────────────────────────────────────
atr_now   = ta.atr(atr_len)
atr_mean  = ta.sma(atr_now, atr_hist_bars)
atr_ratio = atr_mean > 0 ? atr_now / atr_mean : 1.0
vol_avg   = ta.sma(volume, 20)
vol_ratio = vol_avg > 0 ? volume / vol_avg : 1.0
prev_hi   = ta.highest(high[1], brk_bars)
prev_lo   = ta.lowest(low[1],   brk_bars)
brk_up    = close > prev_hi * (1.0 + brk_margin / 100.0)
brk_down  = close < prev_lo * (1.0 - brk_margin / 100.0)
sl_long   = ta.lowest(low[1],   sl_bars) * 0.998
sl_short  = ta.highest(high[1], sl_bars) * 1.002
sl_dist_l = close > 0 ? (close - sl_long)  / close * 100 : 0.0
sl_dist_s = close > 0 ? (sl_short - close) / close * 100 : 0.0
t1_long   = close + t1_mult * atr_now
t2_long   = close + t2_mult * atr_now
t3_long   = close + t3_mult * atr_now
t1_short  = close - t1_mult * atr_now
t2_short  = close - t2_mult * atr_now
t3_short  = close - t3_mult * atr_now
rr_long   = (close - sl_long)  > 0 ? (t1_long  - close) / (close - sl_long)  : 0.0
rr_short  = (sl_short - close) > 0 ? (close - t1_short) / (sl_short - close) : 0.0

// ─── 信号 ─────────────────────────────────────────────────────────────────────
atr_ok   = atr_ratio >= atr_expand_mult
vol_ok   = vol_ratio >= vol_min
long_ok  = atr_ok and brk_up   and vol_ok and sl_dist_l >= 0.2 and sl_dist_l <= 8.0 and rr_long  >= min_rr1
short_ok = atr_ok and brk_down and vol_ok and sl_dist_s >= 0.2 and sl_dist_s <= 8.0 and rr_short >= min_rr1

var int last_long_bar  = -999
var int last_short_bar = -999
long_fire  = long_ok  and (bar_index - last_long_bar)  >= cooldown_n
short_fire = short_ok and (bar_index - last_short_bar) >= cooldown_n
if long_fire
    last_long_bar := bar_index
if short_fire
    last_short_bar := bar_index

// ─── 评分 ─────────────────────────────────────────────────────────────────────
sc_atr = atr_ratio >= 1.4 ? 35 : atr_ratio >= 1.3 ? 25 : atr_ratio >= 1.2 ? 15 : 5
sc_vol = vol_ratio >= 3.0 ? 25 : vol_ratio >= 2.0 ? 18 : vol_ratio >= 1.5 ? 12 : 6
sc     = sc_atr + sc_vol

// ─── 视觉：箭头形状（最清晰）────────────────────────────────────────────────
plotshape(long_fire  and show_long,  title="多头箭头", location=location.belowbar, style=shape.triangleup,   size=size.normal, color=color.new(#00E5FF, 0), text="")
plotshape(short_fire and show_short, title="空头箭头", location=location.abovebar, style=shape.triangledown, size=size.normal, color=color.new(#FF1744, 0), text="")

// ─── 视觉：标签（详细信息）──────────────────────────────────────────────────
if long_fire and show_long
    label.new(bar_index, low - atr_now * 0.8, text="▲ LONG\n" + str.tostring(close, "#.##") + "\nRR " + str.tostring(rr_long, "#.#") + "  ATR×" + str.tostring(atr_ratio, "#.##"), style=label.style_label_up, color=#00BCD4, textcolor=color.white, size=size.small)

if short_fire and show_short
    label.new(bar_index, high + atr_now * 0.8, text="▼ SHORT\n" + str.tostring(close, "#.##") + "\nRR " + str.tostring(rr_short, "#.#") + "  ATR×" + str.tostring(atr_ratio, "#.##"), style=label.style_label_down, color=#F44336, textcolor=color.white, size=size.small)

// ─── 视觉：止盈止损线（持续显示）────────────────────────────────────────────
var float v_sl = na
var float v_t1 = na
var float v_t2 = na
var float v_t3 = na
var color v_col = color.gray

if long_fire
    v_sl  := sl_long
    v_t1  := t1_long
    v_t2  := t2_long
    v_t3  := t3_long
    v_col := #00BCD4

if short_fire
    v_sl  := sl_short
    v_t1  := t1_short
    v_t2  := t2_short
    v_t3  := t3_short
    v_col := #F44336

p_sl = plot(show_levels ? v_sl : na, "止损", color=color.new(#FF5252, 0),  linewidth=2, style=plot.style_linebr)
p_t1 = plot(show_levels ? v_t1 : na, "T1",   color=color.new(#69F0AE, 0),  linewidth=2, style=plot.style_linebr)
p_t2 = plot(show_levels ? v_t2 : na, "T2",   color=color.new(#00E676, 0),  linewidth=2, style=plot.style_linebr)
p_t3 = plot(show_levels ? v_t3 : na, "T3",   color=color.new(#00C853, 0),  linewidth=3, style=plot.style_linebr)

// ─── 视觉：止损区域填充 ──────────────────────────────────────────────────────
p_close = plot(close, display=display.none)
fill(p_sl, p_t1, color=color.new(#69F0AE, 88), title="T1区间")
fill(p_t1, p_t2, color=color.new(#00E676, 92), title="T2区间")

// ─── 视觉：ATR扩张背景（更明显）─────────────────────────────────────────────
bgcolor(show_bg and atr_ratio >= atr_expand_mult ? color.new(#FFF176, 85) : na, title="ATR扩张")

// ─── 警报 ─────────────────────────────────────────────────────────────────────
alertcondition(long_fire,               "D1 多头启动", "D1多头启动")
alertcondition(short_fire,              "D1 空头启动", "D1空头启动")
alertcondition(long_fire or short_fire, "D1 任意方向", "D1启动信号")
