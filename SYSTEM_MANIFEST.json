  "design_philosophy": {
    "core": "胜败不是币的问题，是结构识别能力的问题",
    "wrong_path": "封禁更多标的 → 系统越来越封闭 → 最终无路可走",
    "right_path": "提升结构识别能力 → 让市场告诉我们哪里有机会",
    "structure_axiom": {
      "gap_0_0.5pct": "WR=3% — 无结构，必败",
      "gap_0.5_1pct": "WR=40% — 弱结构",
      "gap_1.5_4pct": "WR=100% — 强结构，必胜",
      "conclusion": "gap = 结构质量的天然度量，不需要封禁标的"
    },
